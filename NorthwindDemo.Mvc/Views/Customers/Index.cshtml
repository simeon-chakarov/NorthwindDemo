@model NorthwindDemo.Mvc.ViewModels.CustomerIndexViewModel

<h2>Customers</h2>

<form method="get" class="d-flex gap-2">
    <input type="text"
           name="search"
           value="@Model.Search"
           class="form-control"
           style="max-width: 300px;"
           placeholder="Search by company name..." />

    <button type="submit" class="btn btn-primary">Search</button>
</form>
<br/>
<table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Company</th>
            <th>Orders</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in Model.Customers)
        {
            <tr>
                <td>@c.CompanyName</td>
                <td>@c.OrdersCount</td>
                <td>
                    <a asp-action="Details" asp-route-id="@c.Id">Details</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<script>
    fetch('https://localhost:7013/api/customers')
      .then(r => r.json())
      .then(_ => console.log('CORS OK'))
      .catch(e => console.error('CORS FAIL', e));
</script>
