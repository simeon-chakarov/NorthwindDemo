@model NorthwindDemo.Mvc.ViewModels.CustomerDetailsViewModel

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="m-0">@Model.Customer.CompanyName</h2>
    <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <div class="text-muted small">Customer ID</div>
                <div class="fw-semibold">@Model.Customer.Id</div>
            </div>

            <div class="col-md-6">
                <div class="text-muted small">Contact</div>
                <div class="fw-semibold">
                    @(string.IsNullOrWhiteSpace(Model.Customer.ContactName) ? "-" : Model.Customer.ContactName)
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.Customer.ContactTitle))
                {
                    <div class="text-muted small">@Model.Customer.ContactTitle</div>
                }
            </div>

            <div class="col-md-6">
                <div class="text-muted small">Location</div>
                <div class="fw-semibold">
                    @(string.IsNullOrWhiteSpace(Model.Customer.City) ? "-" : Model.Customer.City),
                    @(string.IsNullOrWhiteSpace(Model.Customer.Country) ? "-" : Model.Customer.Country)
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.Customer.Address))
                {
                    <div class="text-muted small">@Model.Customer.Address</div>
                }
            </div>

            <div class="col-md-6">
                <div class="text-muted small">Phone</div>
                <div class="fw-semibold">
                    @(string.IsNullOrWhiteSpace(Model.Customer.Phone) ? "-" : Model.Customer.Phone)
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.Customer.Fax))
                {
                    <div class="text-muted small">Fax: @Model.Customer.Fax</div>
                }
            </div>
        </div>
    </div>
</div>

<div class="d-flex align-items-center justify-content-between mb-2">
    <h3 class="m-0">Orders</h3>
    <span class="text-muted">
        Total: @Model.Orders.Count
    </span>
</div>

@if (Model.Orders.Count == 0)
{
    <div class="alert alert-info">
        No orders found for this customer.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th style="width: 120px;">Order #</th>
                    <th style="width: 160px;">Date</th>
                    <th style="width: 160px;">Total</th>
                    <th style="width: 140px;">Products</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in Model.Orders)
                {
                    var hasWarning = !string.IsNullOrWhiteSpace(o.FulfillmentWarning);

                    <tr>
                        <td class="fw-semibold">@o.OrderId</td>
                        <td>@(o.OrderDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                        <td>@o.Total.ToString("C")</td>
                        <td>@o.ProductsCount</td>
                        <td>
                            @if (hasWarning)
                            {
                                <span class="badge bg-warning text-dark">Warning</span>
                                <span class="ms-2 text-muted">@o.FulfillmentWarning</span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}